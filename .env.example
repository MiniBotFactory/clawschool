# ClawSchool 环境变量配置

# Supabase 配置
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenRouter.ai 配置 (支持多个 LLM 模型)
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# GitHub API 配置 (用于自动收集)
VITE_GITHUB_TOKEN=your_github_token_here

# ==================== LLM 模型配置 ====================
# 选择你想要使用的模型（在 https://openrouter.ai/models 查看所有可用模型）

# 默认模型（用于所有任务，除非单独指定）
# 🆓 免费: google/gemini-2.0-flash-exp:free
# 💰 推荐: anthropic/claude-3.5-sonnet
VITE_DEFAULT_LLM_MODEL=google/gemini-2.0-flash-exp:free

# 内容分析（资源质量评估、分类）
# 适合：免费模型即可，需要快速处理大量内容
VITE_CONTENT_ANALYSIS_MODEL=google/gemini-2.0-flash-exp:free

# 课程生成（大纲、内容）
# 适合：高质量模型，需要创意和准确
VITE_COURSE_GENERATION_MODEL=anthropic/claude-3.5-sonnet

# 仓库评估（安全分析、代码质量）
# 适合：高质量模型，需要详细分析
VITE_REPOSITORY_EVALUATION_MODEL=anthropic/claude-3.5-sonnet

# 聊天对话（用户交互）
# 适合：快速响应，成本敏感
VITE_CHAT_MODEL=openai/gpt-4o-mini

# ==================== 可用模型参考 ====================
# 🆓 免费模型（推荐先用这些测试）
# google/gemini-2.0-flash-exp:free

# 💰 付费模型（按价格从低到高）
# openai/gpt-4o-mini ($0.15/1M input tokens)
# anthropic/claude-3-haiku ($0.25/1M input tokens)
# openai/gpt-4o ($2.50/1M input tokens)
# google/gemini-pro-1.5 ($1.25/1M input tokens)
# anthropic/claude-3.5-sonnet ($3/1M input tokens)

# 应用配置
VITE_APP_URL=https://clawschool-five.vercel.app